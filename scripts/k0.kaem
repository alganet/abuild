# Architecture-specific toolchain files
# (aarch64 needs special handling: stage0-posix uses AArch64 for dir/files)
if match ${ARCH} x86
then
    ARG=/${ARCH}; putdir
    ARG=/${ARCH}.answers; putfile
    ARG=/${ARCH}/artifact; putdir
    ARG=/${ARCH}/bin; putdir
    ARG=/${ARCH}/catm_${ARCH}.hex2; putfile
    ARG=/${ARCH}/cc_${ARCH}.M1; putfile
    ARG=/${ARCH}/hex0_${ARCH}.hex0; putfile
    ARG=/${ARCH}/hex1_${ARCH}.hex0; putfile
    ARG=/${ARCH}/hex2_${ARCH}.hex1; putfile
    ARG=/${ARCH}/kaem-minimal.hex0; putfile
    ARG=/${ARCH}/kaem.run; putfile
    ARG=/${ARCH}/libc-core.M1; putfile
    ARG=/${ARCH}/M0_${ARCH}.hex2; putfile
    ARG=/${ARCH}/mescc-tools-full-kaem.kaem; putfile
    ARG=/${ARCH}/mescc-tools-mini-kaem.kaem; putfile
    ARG=/${ARCH}/mescc-tools-seed-kaem.kaem; putfile
    ARG=/${ARCH}/${ARCH}_defs.M1; putfile
fi
if match ${ARCH} riscv64
then
    ARG=/${ARCH}; putdir
    ARG=/${ARCH}.answers; putfile
    ARG=/${ARCH}/artifact; putdir
    ARG=/${ARCH}/bin; putdir
    ARG=/${ARCH}/catm_${ARCH}.hex2; putfile
    ARG=/${ARCH}/cc_${ARCH}.M1; putfile
    ARG=/${ARCH}/hex0_${ARCH}.hex0; putfile
    ARG=/${ARCH}/hex1_${ARCH}.hex0; putfile
    ARG=/${ARCH}/hex2_${ARCH}.hex1; putfile
    ARG=/${ARCH}/kaem-minimal.hex0; putfile
    ARG=/${ARCH}/kaem.run; putfile
