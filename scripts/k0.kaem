    ARG=/${ARCH}/M0.hex2; putfile
    ARG=/${ARCH}/PE32-${ARCH}.hex2; putfile
    ARG=/${ARCH}/cc_${ARCH}.M1; putfile
    ARG=/${ARCH}/kaem.run; putfile
    ARG=/${ARCH}/mescc-tools-seed-kaem.kaem; putfile
    ARG=/${ARCH}/mescc-tools-mini-kaem.kaem; putfile
    ARG=/${ARCH}/mescc-tools-full-kaem.kaem; putfile
    ARG=/EFI; putdir
    ARG=/EFI/BOOT; putdir
    ARG=/EFI/BOOT/BOOTX64.EFI; putfile
    ARG=/bootstrap-seeds/UEFI; putdir
    ARG=/bootstrap-seeds/UEFI/${ARCH}; putdir
    ARG=/bootstrap-seeds/UEFI/${ARCH}/hex0-seed.efi; putfile
    ARG=/bootstrap-seeds/UEFI/${ARCH}/kaem-optional-seed.efi; putfile
    ARG=/posix-runner; putdir
    ARG=/posix-runner/posix-runner.c; putfile
fi

