M2LIBC_PATH="/M2libc"
PATH="/${STAGE0_HOST}/bin:/bin"
TMPDIR="/tmp"

alias create_file="replace${EXE_SUFFIX} --file /scripts/noop.kaem --match-on \# --replace-with"
alias putdir="/${STAGE0_HOST}/bin/kaem${EXE_SUFFIX} --file /scripts/putdir.kaem"
alias putfile="/${STAGE0_HOST}/bin/kaem${EXE_SUFFIX} --file /scripts/putfile.kaem"

cd /
mkdir${EXE_SUFFIX} -p /tmp
mkdir${EXE_SUFFIX} -p /bin
mkdir${EXE_SUFFIX} -p /bootstrap-seeds
mkdir${EXE_SUFFIX} -p /bootstrap-seeds/NATIVE
mkdir${EXE_SUFFIX} -p /bootstrap-seeds/NATIVE/${ARCH}/

catm${EXE_SUFFIX} after.kaem /scripts/env.${ARCH}.kaem /scripts/k0-boot.kaem

kaem${EXE_SUFFIX} --file /scripts/tools.kaem

cd /tmp

# ============================================================
# Init: architecture kernel bootstrap and bh0 header
# ============================================================

if match${EXE_SUFFIX} ${ARCH} x86
then
    /bootstrap-seeds/POSIX/x86/hex0-seed /x86/hex0_x86.hex0 /x86/artifact/hex0
    chmod${EXE_SUFFIX} 755 /x86/artifact/hex0
    /x86/artifact/hex0 /builder-hex0-arch/builder-hex0-x86-stage1-bios.hex0 /bootstrap-seeds/NATIVE/x86/builder-hex0-x86-stage1.img
    catm${EXE_SUFFIX} curr /bootstrap-seeds/NATIVE/x86/builder-hex0-x86-stage1.img
    catm${EXE_SUFFIX} prev curr
    dd${EXE_SUFFIX} if=prev bs=512 of=next
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
    catm${EXE_SUFFIX} next /builder-hex0-arch/builder-hex0-x86-stage2.hex0
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
    dd${EXE_SUFFIX} if=prev bs=512 of=next
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
fi

if match${EXE_SUFFIX} ${ARCH} riscv64
then
    catm${EXE_SUFFIX} prev /builder-hex0-arch/builder-hex0-riscv64-stage2.hex0
    catm${EXE_SUFFIX} curr prev
    dd${EXE_SUFFIX} if=curr bs=512 of=next
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
fi

if match${EXE_SUFFIX} ${ARCH} aarch64
then
    catm${EXE_SUFFIX} prev /builder-hex0-arch/builder-hex0-aarch64-stage2.hex0
    catm${EXE_SUFFIX} curr prev
    dd${EXE_SUFFIX} if=curr bs=512 of=next
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
fi

if match${EXE_SUFFIX} ${ARCH} amd64
then
    dd${EXE_SUFFIX} if=/scripts/noop.kaem bs=512 of=prev
    dd${EXE_SUFFIX} if=/scripts/noop.kaem bs=512 of=next
    catm${EXE_SUFFIX} curr prev next
    catm${EXE_SUFFIX} prev curr
fi

# ============================================================
# Shared entries: scripts, sources, tools
# ============================================================

ARG=/; putdir
ARG=/dev; putdir

ARG=/seal; putfile
ARG=/after.kaem; putfile

ARG=/scripts; putdir
ARG=/scripts/pre-build.kaem; putfile
ARG=/scripts/seal-break.kaem; putfile
ARG=/scripts/seal-break-uefi.kaem; putfile
ARG=/scripts/broken-seal; putfile
ARG=/scripts/k0.kaem; putfile
ARG=/scripts/k1.kaem; putfile
ARG=/scripts/putdir.kaem; putfile
ARG=/scripts/putfile.kaem; putfile
ARG=/scripts/noop.kaem; putfile
ARG=/scripts/tools.kaem; putfile
ARG=/scripts/mes.kaem; putfile
ARG=/scripts/env.${ARCH}.kaem; putfile
ARG=/scripts/k0-boot.kaem; putfile

