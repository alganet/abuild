M2LIBC_PATH="/M2libc"
PATH="/${STAGE0_HOST}/bin:/bin"
TMPDIR="/tmp"

alias create_file="replace --file /scripts/noop.kaem --match-on \# --replace-with"
alias putdir="/${STAGE0_HOST}/bin/kaem --file /scripts/putdir.kaem"
alias putfile="/${STAGE0_HOST}/bin/kaem --file /scripts/putfile.kaem"

cd /
mkdir -p /tmp
mkdir -p /bin
mkdir -p /bootstrap-seeds
mkdir -p /bootstrap-seeds/NATIVE
mkdir -p /bootstrap-seeds/NATIVE/${ARCH}/

catm after.kaem /scripts/env.${ARCH}.kaem /scripts/k1.kaem

kaem --file /scripts/tools.kaem

cd /tmp

# x86: hex0-seed -> hex0 -> stage1.img, then stage1 + stage2 disk assembly
if match ${ARCH} x86
then
    /bootstrap-seeds/POSIX/x86/hex0-seed /x86/hex0_x86.hex0 /x86/artifact/hex0
    chmod 755 /x86/artifact/hex0
    /x86/artifact/hex0 /builder-hex0-arch/builder-hex0-x86-stage1-bios.hex0 /bootstrap-seeds/NATIVE/x86/builder-hex0-x86-stage1.img
    catm curr /bootstrap-seeds/NATIVE/x86/builder-hex0-x86-stage1.img
    catm prev curr
    dd if=prev bs=512 of=next
    catm curr prev next
    catm prev curr
    catm next /builder-hex0-arch/builder-hex0-x86-stage2.hex0
    catm curr prev next
    catm prev curr
    dd if=prev bs=512 of=next
    catm curr prev next
    catm prev curr
fi

# riscv64: stage2 only (stage1 is the kernel, provided externally)
if match ${ARCH} riscv64
then
    catm prev /builder-hex0-arch/builder-hex0-riscv64-stage2.hex0
    catm curr prev
    dd if=curr bs=512 of=next
    catm curr prev next
    catm prev curr
fi

# aarch64: stage2 only (stage1 is the kernel, provided externally)
if match ${ARCH} aarch64
then
    catm prev /builder-hex0-arch/builder-hex0-aarch64-stage2.hex0
    catm curr prev
    dd if=curr bs=512 of=next
    catm curr prev next
    catm prev curr
fi

ARG=/; putdir
ARG=/dev; putdir

ARG=/seal; putfile
ARG=/after.kaem; putfile

ARG=/scripts; putdir
ARG=/scripts/pre-build.kaem; putfile
ARG=/scripts/seal-break.kaem; putfile
ARG=/scripts/k0.kaem; putfile
ARG=/scripts/k1.kaem; putfile
ARG=/scripts/putdir.kaem; putfile
ARG=/scripts/putfile.kaem; putfile
ARG=/scripts/noop.kaem; putfile
ARG=/scripts/tools.kaem; putfile
ARG=/scripts/env.${ARCH}.kaem; putfile

ARG=/bootstrap-seeds; putdir
ARG=/bootstrap-seeds/POSIX; putdir
if match ${ARCH} aarch64
then
    ARG=/bootstrap-seeds/POSIX/AArch64; putdir
fi
if match ${ARCH} x86
then
    ARG=/bootstrap-seeds/POSIX/${ARCH}; putdir
fi
if match ${ARCH} riscv64
then
