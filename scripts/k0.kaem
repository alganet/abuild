# Architecture-specific M2libc files (putdirs already emitted above)
ARG=/M2libc/${ARCH}/linux/bootstrap.c; putfile
ARG=/M2libc/${ARCH}/ELF-${ARCH}.hex2; putfile
ARG=/M2libc/${ARCH}/ELF-${ARCH}-debug.hex2; putfile
ARG=/M2libc/${ARCH}/libc-core.M1; putfile
ARG=/M2libc/${ARCH}/libc-full.M1; putfile
ARG=/M2libc/${ARCH}/${ARCH}_defs.M1; putfile

# Architecture-specific toolchain ELF and builder files
if match ${ARCH} x86
then
    ARG=/x86/ELF-i386.hex2; putfile
    ARG=/builder-hex0-arch; putdir
    ARG=/builder-hex0-arch/builder-hex0-x86-stage2.hex0; putfile
    ARG=/builder-hex0-arch/builder-hex0-x86-stage1-bios.hex0; putfile
fi
if match ${ARCH} riscv64
then
    ARG=/riscv64/ELF-riscv64.hex2; putfile
    ARG=/riscv64/ELF-riscv64-debug.hex2; putfile
    ARG=/builder-hex0-arch; putdir
    ARG=/builder-hex0-arch/builder-hex0-riscv64-stage2.hex0; putfile
fi
if match ${ARCH} aarch64
then
    ARG=/AArch64/ELF-aarch64.hex2; putfile
    ARG=/AArch64/ELF-aarch64-debug.hex2; putfile
    ARG=/builder-hex0-arch; putdir
    ARG=/builder-hex0-arch/builder-hex0-aarch64-stage2.hex0; putfile
fi

if match ${ARCH} aarch64
then
    create_file "hex0 /AArch64/hex0_AArch64.hex0 /bootstrap-seeds/POSIX/AArch64/hex0-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "hex0 /AArch64/kaem-minimal.hex0 /bootstrap-seeds/POSIX/AArch64/kaem-optional-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "/bootstrap-seeds/POSIX/AArch64/kaem-optional-seed /kaem.aarch64" --output next
    catm curr prev next
    catm prev curr
fi
if match ${ARCH} x86
then
    create_file "hex0 /${ARCH}/hex0_${ARCH}.hex0 /bootstrap-seeds/POSIX/${ARCH}/hex0-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "hex0 /${ARCH}/kaem-minimal.hex0 /bootstrap-seeds/POSIX/${ARCH}/kaem-optional-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "/bootstrap-seeds/POSIX/${ARCH}/kaem-optional-seed /kaem.${ARCH}" --output next
    catm curr prev next
    catm prev curr
fi
if match ${ARCH} riscv64
then
    create_file "hex0 /${ARCH}/hex0_${ARCH}.hex0 /bootstrap-seeds/POSIX/${ARCH}/hex0-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "hex0 /${ARCH}/kaem-minimal.hex0 /bootstrap-seeds/POSIX/${ARCH}/kaem-optional-seed" --output next
    catm curr prev next
    catm prev curr

    create_file "/bootstrap-seeds/POSIX/${ARCH}/kaem-optional-seed /kaem.${ARCH}" --output next
    catm curr prev next
    catm prev curr
fi

dd if=prev bs=8388608 of=next
catm curr prev next
catm prev curr

mkdir -p /dev
catm /dev/hda curr
