wc -c "${ARG}"
replace --file /scripts/noop.kaem --match-on \# --replace-with "src " --output /tmp/p
dd if=/tmp/p bs=4 count=1 of=/tmp/q
catm next /tmp/q /dev/stdout
catm curr prev next "${ARG}"
catm prev curr
